[run]
source = .
branch = True
parallel = True
omit =
    */test/*
    */tests/*
    */__pycache__/*
    */venv/*
    */env/*
    */site-packages/*
    htmlcov/*
    conftest.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if (typing\.)?TYPE_CHECKING:
    @(abc\.)?abstractmethod
    except ImportError
    except ModuleNotFoundError
    class.*:
        pass
ignore_errors = True

[html]
directory = htmlcov
show_contexts = True

[paths]
source =
    .
    */site-packages
